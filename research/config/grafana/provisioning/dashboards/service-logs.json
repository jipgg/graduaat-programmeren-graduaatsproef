{
  "annotations": { "list": [] },
  "description": "Structured logs from mock API services — volume overview and searchable log stream.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "schemaVersion": 38,
  "tags": ["logs", "loki"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": {
          "type": 1,
          "label": "service",
          "stream": "",
          "refId": "LokiVariableQueryEditor-VariableQuery"
        },
        "current": {},
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "error,warn,info,debug,trace",
        "current": { "value": "$__all", "text": "All" },
        "includeAll": true,
        "multi": true,
        "hide": 0,
        "options": [
          { "value": "$__all", "text": "All",   "selected": true  },
          { "value": "error",  "text": "error",  "selected": false },
          { "value": "warn",   "text": "warn",   "selected": false },
          { "value": "info",   "text": "info",   "selected": false },
          { "value": "debug",  "text": "debug",  "selected": false },
          { "value": "trace",  "text": "trace",  "selected": false }
        ]
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": { "value": "", "text": "" },
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Service Logs",
  "uid": "service-logs",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Rate by Service",
      "description": "Logs per second emitted by each service.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (rate({service=~\"$service\", level=~\"$level\"} [$__interval]))",
          "legendFormat": "{{service}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "description": "Logs per second broken down by severity — errors and warnings stand out.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({service=~\"$service\", level=~\"$level\"} [$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Log Stream",
      "description": "Live log stream. Use the Search box to filter by any field value (case-insensitive). Click a log line to expand parsed fields — trace_id links to Tempo.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 22, "w": 24, "x": 0, "y": 7 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=~\"$service\", level=~\"$level\"} |~ \"(?i)$search\"",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      }
    }
  ]
}

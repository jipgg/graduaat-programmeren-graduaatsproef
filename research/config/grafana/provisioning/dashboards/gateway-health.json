{
  "__inputs": [
    {
      "name": "thanos",
      "label": "Thanos",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "APISIX gateway operational health — request rates, error rates, latency distribution, connection state, and upstream health.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "schemaVersion": 38,
  "tags": ["apisix", "gateway"],
  "templating": {
    "list": [
      {
        "name": "interval",
        "label": "Rate interval",
        "type": "interval",
        "query": "1m,5m,15m",
        "current": { "value": "5m", "text": "5m" },
        "options": [
          { "value": "1m",  "text": "1m",  "selected": false },
          { "value": "5m",  "text": "5m",  "selected": true  },
          { "value": "15m", "text": "15m", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "APISIX — Gateway Health",
  "uid": "apisix-gateway-health",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate",
      "description": "Total HTTP requests/s through the gateway.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_http_requests_total[$interval]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Error Rates",
      "description": "5xx (server errors) and 4xx (client errors) per second.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_http_status_total{code=~\"5..\"}[$interval]))",
          "legendFormat": "5xx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_http_status_total{code=~\"4..\"}[$interval]))",
          "legendFormat": "4xx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency Percentiles (P50 / P95 / P99)",
      "description": "End-to-end request latency. 'apisix' = gateway processing only, 'upstream' = backend response.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(apisix_http_latency_bucket{type=\"request\"}[$interval])))",
          "legendFormat": "P50 end-to-end",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apisix_http_latency_bucket{type=\"request\"}[$interval])))",
          "legendFormat": "P95 end-to-end",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(apisix_http_latency_bucket{type=\"request\"}[$interval])))",
          "legendFormat": "P99 end-to-end",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apisix_http_latency_bucket{type=\"apisix\"}[$interval])))",
          "legendFormat": "P95 gateway only",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apisix_http_latency_bucket{type=\"upstream\"}[$interval])))",
          "legendFormat": "P95 upstream only",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Connections",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(apisix_nginx_http_current_connections{state=\"active\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Gateway P95 Latency",
      "description": "APISIX processing overhead, excluding upstream response time.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apisix_http_latency_bucket{type=\"apisix\"}[$interval])))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Upstream P95 Latency",
      "description": "Backend service response time at P95.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apisix_http_latency_bucket{type=\"upstream\"}[$interval])))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Bandwidth (total)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_bandwidth_total[$interval]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "binBps" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Upstream Node Health",
      "description": "1 = healthy, 0 = unhealthy. Populated only when APISIX health checks are configured.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "apisix_upstream_status",
          "legendFormat": "{{name}} {{ip}}:{{port}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "unhealthy" }, "1": { "text": "healthy" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "desc": false, "displayName": "Status" }]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Ingress / Egress Bandwidth",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_bandwidth_total{type=\"ingress\"}[$interval]))",
          "legendFormat": "ingress",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_bandwidth_total{type=\"egress\"}[$interval]))",
          "legendFormat": "egress",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "NGINX Connection States",
      "description": "active = connections being processed; waiting = keep-alive idle; reading/writing = in-flight.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "apisix_nginx_http_current_connections",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}

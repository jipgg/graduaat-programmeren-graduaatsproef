{
  "__inputs": [
    {
      "name": "thanos",
      "label": "Thanos",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "Per-route and per-consumer traffic analysis — volume, error rates, latency, and bandwidth breakdowns.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "schemaVersion": 38,
  "tags": ["apisix", "api", "consumers"],
  "templating": {
    "list": [
      {
        "name": "interval",
        "label": "Rate interval",
        "type": "interval",
        "query": "1m,5m,15m",
        "current": { "value": "5m", "text": "5m" },
        "options": [
          { "value": "1m",  "text": "1m",  "selected": false },
          { "value": "5m",  "text": "5m",  "selected": true  },
          { "value": "15m", "text": "15m", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "route",
        "label": "Route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "thanos" },
        "query": "label_values(apisix_http_status_total, route)",
        "refresh": 2,
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1
      },
      {
        "name": "consumer",
        "label": "Consumer",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "thanos" },
        "query": "label_values(apisix_http_status_total, consumer)",
        "refresh": 2,
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "APISIX — API & Consumer Usage",
  "uid": "apisix-consumer-usage",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Top 10 Routes by Request Volume",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "topk(10, sum by (route) (rate(apisix_http_status_total[${interval}])))",
          "legendFormat": "{{route}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Top Consumers by Traffic",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "topk(10, sum by (consumer) (rate(apisix_http_status_total{consumer!=\"\"}[${interval}])))",
          "legendFormat": "{{consumer}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Rate by Route",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (route) (rate(apisix_http_status_total{route=~\"$route\"}[$interval]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P95 Latency by Route",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(apisix_http_latency_bucket{type=\"request\",route=~\"$route\"}[$interval])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Error Rate by Route (4xx + 5xx)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (route, code) (rate(apisix_http_status_total{code=~\"[45]..\",route=~\"$route\"}[$interval]))",
          "legendFormat": "{{route}} {{status}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "code" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 400 },
                    { "color": "red", "value": 500 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "rate (req/s)" }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "desc": true, "displayName": "rate (req/s)" }]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Bandwidth by Service",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (route) (rate(apisix_bandwidth_total{type=\"ingress\"}[$interval]))",
          "legendFormat": "{{route}} ingress",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (route) (rate(apisix_bandwidth_total{type=\"egress\"}[$interval]))",
          "legendFormat": "{{route}} egress",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Consumer Error Rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (consumer, route) (rate(apisix_http_status_total{code=~\"5..\",consumer=~\"$consumer\",consumer!=\"\"}[$interval]))",
          "legendFormat": "{{consumer}} / {{route}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "5xx rate (req/s)" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 0.01 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "desc": true, "displayName": "5xx rate (req/s)" }]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request Rate by Consumer",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (consumer) (rate(apisix_http_status_total{consumer=~\"$consumer\",consumer!=\"\"}[$interval]))",
          "legendFormat": "{{consumer}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    }
  ]
}

{
  "__inputs": [
    {
      "name": "thanos",
      "label": "Thanos",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "SLA compliance, error breakdown by route/consumer/URI, P99 latency, and bandwidth efficiency.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "schemaVersion": 38,
  "tags": ["apisix", "sla", "errors"],
  "templating": {
    "list": [
      {
        "name": "interval",
        "label": "Rate interval",
        "type": "interval",
        "query": "1m,5m,15m",
        "current": { "value": "5m", "text": "5m" },
        "options": [
          { "value": "1m",  "text": "1m",  "selected": false },
          { "value": "5m",  "text": "5m",  "selected": true  },
          { "value": "15m", "text": "15m", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "APISIX — SLA & Errors",
  "uid": "apisix-sla-errors",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Overall Success Rate",
      "description": "Fraction of all requests returning 2xx. Target ≥ 99.9%.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_http_status_total{code=~\"2..\"}[$interval])) / sum(rate(apisix_http_status_total[$interval]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null  },
              { "color": "yellow", "value": 0.99  },
              { "color": "green",  "value": 0.999 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SLO — Requests < 200 ms",
      "description": "Fraction of end-to-end requests completing within 200 ms.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_http_latency_bucket{type=\"request\",le=\"200\"}[$interval])) / sum(rate(apisix_http_latency_bucket{type=\"request\",le=\"+Inf\"}[$interval]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.8  },
              { "color": "green",  "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SLO — Requests < 500 ms",
      "description": "Fraction of end-to-end requests completing within 500 ms.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_http_latency_bucket{type=\"request\",le=\"500\"}[$interval])) / sum(rate(apisix_http_latency_bucket{type=\"request\",le=\"+Inf\"}[$interval]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.9  },
              { "color": "green",  "value": 0.99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "SLO — Requests < 1 s",
      "description": "Fraction of end-to-end requests completing within 1000 ms.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(rate(apisix_http_latency_bucket{type=\"request\",le=\"1000\"}[$interval])) / sum(rate(apisix_http_latency_bucket{type=\"request\",le=\"+Inf\"}[$interval]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null  },
              { "color": "yellow", "value": 0.95  },
              { "color": "green",  "value": 0.999 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "4xx Rate by Route",
      "description": "Client error rate per route. Spikes here indicate auth failures, bad requests, or consumer-restriction blocks.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (route, code) (rate(apisix_http_status_total{code=~\"4..\"}[$interval]))",
          "legendFormat": "{{route}} {{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx Rate by Route",
      "description": "Server error rate per route. Any sustained non-zero value is an incident signal.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (route) (rate(apisix_http_status_total{code=~\"5..\"}[$interval]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 0.001 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "P99 Latency by Consumer",
      "description": "P99 end-to-end latency per consumer. High values on a single consumer may indicate large payloads or abusive polling.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "histogram_quantile(0.99, sum by (consumer, le) (rate(apisix_http_latency_bucket{type=\"request\"}[$interval])))",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "P99 (ms)" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 500  },
                    { "color": "red",    "value": 1000 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "P99 (ms)", "desc": true }] },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Consumer 5xx Error Rate",
      "description": "Server error rate per consumer × route. Identifies which consumer traffic is hitting broken upstreams.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (consumer, route) (rate(apisix_http_status_total{code=~\"5..\"}[$interval])) > 0",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "5xx req/s" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": null  },
                    { "color": "red",    "value": 0.05  }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "5xx req/s", "desc": true }] },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Error Rate by URI",
      "description": "4xx+5xx rate per matched_uri. Reveals which specific endpoints generate the most errors regardless of route grouping.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (matched_uri) (rate(apisix_http_status_total{code=~\"[45]..\"}[$interval]))",
          "legendFormat": "{{matched_uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Avg Bytes per Request by Consumer",
      "description": "Egress bandwidth divided by request count per consumer. High values flag consumers transferring unusually large payloads.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (consumer) (rate(apisix_bandwidth_total{type=\"egress\"}[$interval])) / sum by (consumer) (rate(apisix_http_status_total[$interval]))",
          "legendFormat": "{{consumer}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Top URIs by P99 Latency",
      "description": "Slowest matched URIs by P99 end-to-end latency. Instant snapshot — use to identify slow endpoints.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "topk(10, histogram_quantile(0.99, sum by (matched_uri, le) (rate(apisix_http_latency_bucket{type=\"request\"}[$interval]))))",
          "legendFormat": "{{matched_uri}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "xField": "matched_uri",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal"
      }
    },
    {
      "id": 12,
      "type": "barchart",
      "title": "Top URIs by Error Rate",
      "description": "URIs generating the most 4xx+5xx errors per second. Instant snapshot.",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "topk(10, sum by (matched_uri) (rate(apisix_http_status_total{code=~\"[45]..\"}[$interval])))",
          "legendFormat": "{{matched_uri}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "xField": "matched_uri",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal"
      }
    }
  ]
}
